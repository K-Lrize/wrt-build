#!/bin/sh /etc/rc.common

START=99
USE_PROCD=1

PROG="/usr/bin/sing-box"

start_service() {
	local enabled conffile workdir scriptfile
	config_load 'sing-box'

	config_get_bool enabled 'main' 'enabled' 0
	config_get conffile 'main' 'conffile' '/etc/sing-box/config.json'
	config_get workdir 'main' 'workdir' '/etc/sing-box'
	config_get scriptfile 'main' 'scriptfile' '/etc/sing-box/script.sh'

	[ "$enabled" -eq 0 ] && return

	[ -d "$workdir" ] || mkdir -p "$workdir"

	[ -x "$scriptfile" ] && "$scriptfile" start

	procd_open_instance
	procd_set_param command "$PROG" run -c "$conffile" -D "$workdir"
	procd_set_param respawn
	procd_set_param limits core="unlimited"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	local scriptfile
	config_load 'sing-box'
	config_get scriptfile 'main' 'scriptfile' '/etc/sing-box/script.sh'
	[ -x "$scriptfile" ] && "$scriptfile" stop
}

reload_service() {
	local scriptfile
	config_load 'sing-box'
	config_get scriptfile 'main' 'scriptfile' '/etc/sing-box/script.sh'
	[ -x "$scriptfile" ] && "$scriptfile" restart
}

service_triggers() {
	procd_add_reload_trigger "sing-box"
}
