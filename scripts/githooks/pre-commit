#!/bin/bash
#
# Git Pre-commit 钩子：在本地生成提交前自动排版代码并执行静态检查

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

cd "${REPO_ROOT}"

echo "[INFO] 触发 Pre-commit 钩子：执行项目自动化排版..."
bash scripts/fmt.sh

# 自动将排版整理后的变更更新至暂存区
git add -u

echo "[INFO] 触发 Pre-commit 钩子：执行静态语法校验..."
bash scripts/lint-devices.sh
bash scripts/lint-packages.sh

echo "[ OK ] Pre-commit 校验通过，允许提交。"
